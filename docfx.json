{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "CustomFont",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "output": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "CustomFont",
      "_appTitle": "CustomFont",
      "_enableSearch": true,
      "pdf": false
    },
    "xref": [
      "https://normanderwan.github.io/UnityXrefMaps/6000.0/xrefmap.yml"
    ]
  }
}